# Default: normalize text files using Git's auto detection.
* text=auto

# VBA source modules must stay CRLF for reliable round-tripping.
*.bas text eol=crlf
*.cls text eol=crlf
*.frm text eol=crlf
*.vba text eol=crlf

# Exclude JS/TS files from GitHub language stats.
*.ts linguist-generated=true
*.js linguist-generated=true